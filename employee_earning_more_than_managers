-- Create Employee Table

CREATE TABLE Employee_salary (
    Id INT PRIMARY KEY,
    Name VARCHAR(50),
    Salary INT,
    ManagerId INT
);

-- Insert Sample Data

INSERT INTO Employee_salary (Id, Name, Salary, ManagerId)
VALUES
(1, 'Joe',   70000, 3),
(2, 'Henry', 80000, 4),
(3, 'Sam',   60000, NULL),
(4, 'Max',   90000, NULL);

SOLUTION:
select e.Id, e.Name,e.Salary
from Employee_salary as e
inner join Employee_salary as m
on m.Id = e.ManagerId
where e.Salary > m.Salary
