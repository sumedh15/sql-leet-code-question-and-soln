-- Create Employee Table

CREATE TABLE Employee (
    Id INT PRIMARY KEY,
    Salary INT
);

-- Insert Sample Data

INSERT INTO Employee (Id, Salary)
VALUES
(1, 100),
(2, 200),
(3, 300);

SOLUTION:
with CTE1 AS (
 SELECT
	Salary,
	DENSE_RANK() OVER(order by salary desc) as rn
 FROM employee

)
select salary as SecondHighestSalary
from CTE1
where rn = 2
